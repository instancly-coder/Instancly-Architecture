auto-install-peers=false
strict-peer-dependencies=false

# `@neondatabase/auth@0.2.0-beta.1` ships pre-bundled chunks that import
# `tailwind-merge`, `clsx`, `class-variance-authority`, `next-themes`,
# `sonner`, `react-hook-form`, `lucide-react`, etc. directly — but doesn't
# declare any of them in its own package.json (they're declared in
# `@neondatabase/auth-ui`, which is a transitive dep). Under pnpm's
# strict isolation, that means the chunks can't resolve those imports
# from `node_modules/.pnpm/@neondatabase+auth@.../...`.
#
# Hoist the auth-ui's runtime peer-deps to the workspace root so the
# Neon auth chunks can resolve them. This is a packaging bug in the
# 0.2.0-beta SDK; remove these patterns once they declare their deps
# correctly.
public-hoist-pattern[]=tailwind-merge
public-hoist-pattern[]=clsx
public-hoist-pattern[]=class-variance-authority
public-hoist-pattern[]=next-themes
public-hoist-pattern[]=sonner
public-hoist-pattern[]=lucide-react
public-hoist-pattern[]=react-hook-form
public-hoist-pattern[]=input-otp
public-hoist-pattern[]=vaul
public-hoist-pattern[]=zod
public-hoist-pattern[]=ua-parser-js
public-hoist-pattern[]=react-qr-code
public-hoist-pattern[]=react-google-recaptcha
public-hoist-pattern[]=tw-animate-css
public-hoist-pattern[]=tailwindcss
public-hoist-pattern[]=@hookform/*
public-hoist-pattern[]=@radix-ui/*
public-hoist-pattern[]=@captchafox/*
public-hoist-pattern[]=@hcaptcha/*
public-hoist-pattern[]=@marsidev/*
public-hoist-pattern[]=@wojtekmaj/*
